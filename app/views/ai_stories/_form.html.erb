<%= form_with url: generate_ai__path,
              method: :post,
              class: "ai-story-form" do |form| %>

  <div class="form-group">

    <%= label_tag :epic_id,
        "Select Epic",
        class: "form-label" %>

    <%= select_tag :epic_id,
        options_from_collection_for_select(
          Epic.order(:title),
          :id,
          :title
        ),
        prompt: "Choose Epic",
        class: "form-input" %>

  </div>

  <div class="form-group">

    <%= form.label :feature,
          "Feature Description",
          class: "form-label" %>

    <%= form.text_area :feature,
          rows: 6,
          placeholder: "Example: Build user authentication with login, registration and password reset functionality.",
          class: "ai-story-textarea" %>

  </div>

  <div class="ai-form-actions">

    <%= form.submit "✨ Generate Story",
          class: "ai-story-submit" %>

  </div>

<% end %>