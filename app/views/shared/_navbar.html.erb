<header class="bg-white border-b border-slate-200">

  <div class="flex justify-between items-center px-8 py-5">

    <div>

      <h2 class="text-3xl font-bold text-slate-800">
        <%= content_for?(:page_title) ? yield(:page_title) : "SprintPilot Dashboard" %>
      </h2>

      <p class="text-sm text-slate-500 mt-1">
        AI-powered project management workspace
      </p>

    </div>

    <div class="flex items-center gap-5">

      <!-- Notification -->

      <button
        type="button"
        class="h-11 w-11 rounded-full bg-slate-100 hover:bg-slate-200 transition flex items-center justify-center text-lg">

        🔔

      </button>

      <!-- User Dropdown -->

      <div
        data-controller="dropdown"
        class="relative">

        <button
          type="button"
          data-action="click->dropdown#toggle"
          class="flex items-center gap-3 bg-white px-4 py-2 rounded-2xl shadow-sm border border-slate-200 hover:shadow-md transition">

          <div class="h-11 w-11 rounded-full bg-gradient-to-r from-blue-600 to-purple-600 text-white font-bold flex items-center justify-center">

            <%= current_user.email.first.upcase %>

          </div>

          <div>

            <p class="font-semibold text-slate-800">
              <%= current_user.name.presence || "Admin User" %>
            </p>

            <p class="text-xs text-slate-500">
              Super Admin
            </p>

          </div>

          <span class="text-slate-400 text-xs">
            ▼
          </span>

        </button>

        <!-- Dropdown Menu -->

        <div
          data-dropdown-target="menu"
          class="hidden absolute right-0 mt-3 w-72 bg-white rounded-2xl shadow-xl border border-slate-200 overflow-hidden z-50">

          <div class="p-5 border-b border-slate-100">

            <p class="font-semibold text-slate-800">
              <%= current_user.name.presence || "Admin User" %>
            </p>

            <p class="text-sm text-slate-500 truncate">
              <%= current_user.email %>
            </p>

          </div>

          <%= link_to "#",
                class: "flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition" do %>

            <span>👤</span>
            Profile

          <% end %>

          <%= link_to "#",
                class: "flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition" do %>

            <span>⚙️</span>
            Settings

          <% end %>

          <!-- Appearance -->

          <div class="border-t border-slate-100">

            <div class="px-5 py-3 text-sm font-semibold text-slate-500">

              Appearance

            </div>

            <%= button_to theme_settings_path(theme: :light),
                  method: :patch,
                  form: { data: { turbo: false } },
                  form_class: "w-full" do %>

              <div class="w-full text-left flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition">

                🌞 Light Theme

              </div>

            <% end %>

            <%= button_to theme_settings_path(theme: :dark),
                  method: :patch,
                  form: { data: { turbo: false } },
                  form_class: "w-full" do %>

              <div class="w-full text-left flex items-center gap-3 px-5 py-3 hover:bg-slate-50 transition">

                🌙 Dark Theme

              </div>

            <% end %>

          </div>

          <!-- Logout -->

          <div class="border-t border-slate-100">

            <%= button_to destroy_user_session_path,
                  method: :delete,
                  form: { data: { turbo: false } },
                  form_class: "w-full" do %>

              <div class="flex items-center gap-3 px-5 py-3 text-red-600 hover:bg-red-50 transition">

                <span>🚪</span>

                Logout

              </div>

            <% end %>

          </div>

        </div>

      </div>

    </div>

  </div>

</header>