<% content_for :page_title, "AI Task Generator" %>

<div class="ai-stories-page">

  <div class="ai-stories-header">

    <div>

      <h1 class="ai-stories-title">
        🤖 AI Task Generator
      </h1>

      <p class="ai-stories-subtitle">
        Generate implementation tasks from stories.
      </p>

    </div>

  </div>

  <div class="ai-story-card">

    <%= form_with url: generate_ai_tasks_path do |form| %>

      <div class="form-group">

        <%= form.label :story_id,
            "Select Story",
            class: "form-label" %>

        <%= form.select :story_id,
            @stories.collect { |story| [story.title, story.id] },
            {},
            class: "form-input" %>

      </div>

      <div class="ai-form-actions">

        <%= form.submit "✨ Generate Tasks",
            class: "ai-story-submit" %>

      </div>

    <% end %>

  </div>

  <div id="ai-task-result"></div>

</div>