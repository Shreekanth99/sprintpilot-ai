<%= turbo_stream.update "ai-assistant-result" do %>

  <div class="ai-result-card">

<div class="ai-result-header">

  <h2 class="ai-result-title">
    🤖 AI Result
  </h2>

</div>

<div class="ai-result-content">

  <%= simple_format(@result) %>

</div>

<div class="ai-result-actions">

  <% unless @result.to_s.include?("Error") %>

    <% if @generation_type == "story" %>

      <%= form_with url: save_story_ai_assistant_index_path,
                    method: :post,
                    class: "save-form" do %>

        <div class="form-group">

          <label class="form-label">
            Select Epic
          </label>

          <%= select_tag :epic_id,
              options_from_collection_for_select(
                Epic.order(:title),
                :id,
                :title
              ),
              prompt: "Choose Epic",
              class: "form-select" %>

        </div>

        <div class="action-buttons">

          <%= submit_tag "💾 Save Story",
              class: "save-btn" %>

          <%= link_to "🔄 Regenerate",
              ai_assistant_index_path,
              class: "regenerate-btn" %>

          <%= link_to "⬅ Back",
              ai_assistant_index_path,
              class: "cancel-btn" %>

        </div>

      <% end %>

    <% elsif @generation_type == "task" %>

      <%= form_with url: save_tasks_ai_assistant_index_path,
                    method: :post,
                    class: "save-form" do %>

        <div class="form-group">

          <label class="form-label">
            Select Story
          </label>

          <%= select_tag :story_id,
              options_from_collection_for_select(
                Story.order(:title),
                :id,
                :title
              ),
              prompt: "Choose Story",
              class: "form-select" %>

        </div>

        <div class="action-buttons">

          <%= submit_tag "💾 Save Tasks",
              class: "save-btn" %>

          <%= link_to "🔄 Regenerate",
              ai_assistant_index_path,
              class: "regenerate-btn" %>

          <%= link_to "⬅ Back",
              ai_assistant_index_path,
              class: "cancel-btn" %>

        </div>

      <% end %>

    <% elsif @generation_type == "epic" %>

      <%= form_with url: save_epic_ai_assistant_index_path,
                    method: :post,
                    class: "save-form" do %>

        <div class="form-group">

          <label class="form-label">
            Select Project
          </label>

          <%= select_tag :project_id,
              options_from_collection_for_select(
                Project.order(:name),
                :id,
                :name
              ),
              prompt: "Choose Project",
              class: "form-select" %>

        </div>

        <div class="action-buttons">

          <%= submit_tag "💾 Save Epic",
              class: "save-btn" %>

          <%= link_to "🔄 Regenerate",
              ai_assistant_index_path,
              class: "regenerate-btn" %>

          <%= link_to "⬅ Back",
              ai_assistant_index_path,
              class: "cancel-btn" %>

        </div>

      <% end %>

    <% elsif @generation_type == "sprint" %>

      <%= form_with url: save_sprint_ai_assistant_index_path,
                    method: :post,
                    class: "save-form" do %>

        <div class="form-group">

          <label class="form-label">
            Select Project
          </label>

          <%= select_tag :project_id,
              options_from_collection_for_select(
                Project.order(:name),
                :id,
                :name
              ),
              prompt: "Choose Project",
              class: "form-select" %>

        </div>

        <div class="action-buttons">

          <%= submit_tag "💾 Save Sprint",
              class: "save-btn" %>

          <%= link_to "🔄 Regenerate",
              ai_assistant_index_path,
              class: "regenerate-btn" %>

          <%= link_to "⬅ Back",
              ai_assistant_index_path,
              class: "cancel-btn" %>

        </div>

      <% end %>

    <% end %>

  <% else %>

    <div class="action-buttons">

      <%= link_to "🔄 Try Again",
          ai_assistant_index_path,
          class: "regenerate-btn" %>

      <%= link_to "⬅ Back",
          ai_assistant_index_path,
          class: "cancel-btn" %>

    </div>

  <% end %>

</div>

  </div>

<% end %>
