<div class="stories-page">

  <div class="stories-header">

    <div>

      <h1 class="stories-title">
        📖 Stories
      </h1>

      <p class="stories-subtitle">
        Manage AI-generated and manually created stories.
      </p>

    </div>

    <%= link_to "+ New Story",
        new_story_path,
        class: "primary-btn" %>

  </div>

  <div class="stories-grid">

    <% @stories.each do |story| %>

      <div class="story-card">

        <div class="story-card-header">

          <div class="story-avatar">
            📖
          </div>

          <div>

            <h3 class="story-name">
              <%= story.title %>
            </h3>

            <p class="story-epic">
              <%= story.epic.title %>
            </p>

          </div>

        </div>

        <div class="story-meta">

          <div class="story-stat">
            <span>Story Points</span>
            <strong><%= story.story_points %></strong>
          </div>

          <div class="story-stat">
            <span>Status</span>

            <span class="story-status">
              <%= story.status.titleize %>
            </span>
          </div>

        </div>

        <div class="story-actions">

          <%= link_to "View",
              story,
              class: "btn-view" %>

          <%= link_to "Edit",
              edit_story_path(story),
              class: "btn-edit" %>

          <%= button_to "Delete",
              story_path(story),
              method: :delete,
              class: "btn-delete" %>

        </div>

      </div>

    <% end %>

  </div>

</div>