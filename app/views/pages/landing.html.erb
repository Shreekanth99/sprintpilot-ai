<div class="min-h-screen bg-gradient-to-br from-slate-900 via-blue-900 to-slate-950">

  <div class="container mx-auto px-8">

    <div class="flex flex-col lg:flex-row items-center justify-between min-h-screen">

      <div class="text-white max-w-2xl">

        <h1 class="text-6xl font-bold mb-6">
          SprintPilot AI
        </h1>

        <p class="text-2xl text-blue-200 mb-8">
          AI Powered Agile Project Management Platform
        </p>

        <p class="text-lg text-slate-300 mb-10">
          Manage projects, teams, sprints, stories and tasks
