<%= form_with(model: @sprint, class: "modern-sprint-form") do |form| %>

  <div class="form-grid">

    <div class="form-group full-width">

      <%= form.label :name, class: "form-label" %>

      <%= form.text_field :name,
          class: "form-input",
          placeholder: "Sprint 1 - User Authentication" %>

    </div>

    <div class="form-group full-width">

      <%= form.label :goal, class: "form-label" %>

      <%= form.text_area :goal,
          rows: 5,
          class: "form-textarea",
          placeholder: "Describe sprint objectives..." %>

    </div>

    <div class="form-group">

      <%= form.label :status, class: "form-label" %>

      <%= form.select :status,
          ["planned", "active", "completed"],
          {},
          class: "form-select" %>

    </div>

    <div class="form-group">

      <%= form.label :project_id,
          "Project",
          class: "form-label" %>

      <%= form.collection_select :project_id,
          Project.order(:name),
          :id,
          :name,
          {},
          class: "form-select" %>

    </div>

    <div class="form-group">

      <%= form.label :start_date,
          class: "form-label" %>

      <%= form.date_field :start_date,
          class: "form-input" %>

    </div>

    <div class="form-group">

      <%= form.label :end_date,
          class: "form-label" %>

      <%= form.date_field :end_date,
          class: "form-input" %>

    </div>

  </div>

  <div class="form-actions">

    <%= link_to "Cancel",
        sprints_path,
        class: "cancel-btn" %>

    <%= form.submit "Create Sprint",
        class: "primary-btn" %>

  </div>

<% end %>